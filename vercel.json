{
  "version": 2,
  "public": false,
  "github": {
    "silent": true
  },
  "rewrites": [
    {
      "source": "/assets/images/:slug*",
      "destination": "/api/assets/:slug*"
    },
    {
      "source": "/ref/:slug*",
      "destination": "/api/ref/:slug*"
    },
    {
      "source": "/assess",
      "destination": "/api/assess"
    },
    {
      "source": "/assess/:slug*",
      "destination": "/api/assess/:slug*"
    }
  ]
}
